# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in your keys. `.env.local` is
# git-ignored. Restart `pnpm dev` after editing.
# -----------------------------------------------------------------------------

# Privy app id (https://dashboard.privy.io/ → Create app)
# Without this, the navbar shows a disabled "Configure Privy" button and the
# /trade sidebar falls back to a public preview of the buy/sell UI.
NEXT_PUBLIC_PRIVY_APP_ID=

# Supabase project (https://supabase.com/dashboard → New project)
# Project Settings → API gives you both values.
# Without them, the app keeps using localStorage for the watchlist and
# skips writing positions/profiles — UI keeps working in demo mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# BirdEye Data Services (https://bds.birdeye.so/ → API Keys → Generate)
# SERVER-SIDE ONLY (no NEXT_PUBLIC_ prefix) so the key never reaches the
# browser. All BirdEye calls are proxied through /api/birdeye/* routes.
# Without it, trending list / chart / trades / holders fall back to mocks.
BIRDEYE_API_KEY=

# Alchemy Solana Devnet RPC (https://www.alchemy.com/rpc-api → new app → Solana Devnet)
# Used later for reading on-chain wallet balances + (mock) transactions.
NEXT_PUBLIC_ALCHEMY_SOLANA_DEVNET_URL=
